# Discord Bot Environment Variables
# Copy this file to .env and fill in the values

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord application client ID (from Developer Portal → General Information)
DISCORD_CLIENT_ID=your_client_id_here

# (Optional) Guild ID for development — guild-specific commands deploy instantly
# For production, remove this to deploy commands globally
DISCORD_GUILD_ID=your_guild_id_here

# Backend API URL
BACKEND_URL=http://localhost:4000

# Google Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) Discord channel ID for proactive alert notifications
# The bot will post alerts to this channel when anomalies are detected
ALERT_CHANNEL_ID=your_channel_id_here
